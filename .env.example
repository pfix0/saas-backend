# ══════════════════════════════════════════
# ساس Backend — Environment Variables
# ══════════════════════════════════════════

# ═══ Server ═══
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ═══ Database (Railway PostgreSQL) ═══
DATABASE_URL=postgresql://postgres:password@localhost:5432/saas_db

# ═══ Auth ═══
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ═══ Payment — SADAD ═══
SADAD_MERCHANT_ID=
SADAD_API_KEY=
SADAD_SECRET_KEY=
SADAD_BASE_URL=https://api.sadad.qa

# ═══ Payment — SkipCash ═══
SKIPCASH_KEY_ID=
SKIPCASH_KEY_SECRET=
SKIPCASH_BASE_URL=https://api.skipcash.app

# ═══ Shipping — Aramex ═══
ARAMEX_USERNAME=
ARAMEX_PASSWORD=
ARAMEX_ACCOUNT_NUMBER=
ARAMEX_ACCOUNT_PIN=
ARAMEX_COUNTRY_CODE=QA

# ═══ Shipping — DHL ═══
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=

# ═══ Email (Resend) ═══
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@saas.qa

# ═══ SMS / OTP ═══
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
